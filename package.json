{
  "name": "song-typing",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "tsc -b && vite build",
    "electron": "electron .",
    "preview": "vite preview",
    "dist:win": "tsc -b && vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.songtyping.app",
    "productName": "歌でタイピング",
    "directories": { "output": "release" },
    "files": [
      "dist/**",
      "electron/**",
      "scripts/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["ja-JP"],
      "language": "1041"
    }
  },
  "dependencies": {
    "@vercel/postgres": "^0.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
